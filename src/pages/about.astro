---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { AUTHOR_NAME, EMAIL, GITHUB_URL, SITE_TITLE } from '../consts';

const pageDescription =
	'LUSH, based in Chengdu, works on Web software development, AI application development, NLP, and LLM research.';

const milestones = [
	{
		stage: 'Undergraduate',
		school: 'Yibin University',
		college: 'School of Computer Science and Technology',
		major: 'Software Engineering',
		focus:
			'本科阶段主要从事 Web 软件开发，关注前后端协作、业务功能实现、数据库设计与完整项目落地。',
	},
	{
		stage: 'Graduate',
		school: 'Chengdu University of Technology',
		college: 'College of Computer Science and Cyber Security',
		major: 'Software Engineering',
		focus:
			'研究生阶段主要从事 AI 应用开发，同时关注 NLP 与大模型研究，尝试把模型能力和真实应用场景结合起来。',
	},
];

const focusCards = [
	{
		title: 'Web Software Development',
		stage: 'Undergraduate Focus',
		text: '本科阶段的主要实践方向，围绕 Web 业务系统进行页面、接口、数据和功能模块的开发。',
	},
	{
		title: 'AI Application Development',
		stage: 'Graduate Focus',
		text: '研究生阶段的重要实践方向，关注如何把模型、数据、工具链和具体业务流程连接起来。',
	},
	{
		title: 'NLP & LLM Research',
		stage: 'Research Interest',
		text: '研究生阶段持续关注的研究内容，聚焦自然语言处理、大模型能力以及应用场景中的落地价值。',
	},
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`About ${AUTHOR_NAME} | ${SITE_TITLE}`} description={pageDescription} />
	</head>
	<body>
		<Header />
		<main class="about-page">
			<section class="about-hero" aria-labelledby="about-title">
				<div class="about-backdrop" aria-hidden="true"></div>
				<div class="about-copy">
					<p class="eyebrow">about // profile</p>
					<h1 id="about-title">About {AUTHOR_NAME}</h1>
					<p class="lead">
						你好，我是 LUSH，来自四川。目前就读软件工程专业，
						本科阶段主要做 Web 软件开发，研究生阶段主要从事 AI 应用开发，并关注 NLP 与大模型研究方向。
					</p>
					<div class="about-actions" aria-label="Contact links">
						<a class="primary-action" href={GITHUB_URL} target="_blank" rel="noreferrer">GitHub</a>
						<a class="ghost-action" href={`mailto:${EMAIL}`}>{EMAIL}</a>
					</div>
				</div>

				<aside class="identity-panel" aria-label="LUSH identity summary">
					<div class="panel-topbar">
						<span></span>
						<span></span>
						<span></span>
						<strong>LUSH.profile</strong>
					</div>
					<dl>
						<div>
							<dt>Base</dt>
							<dd>Chengdu, Sichuan</dd>
						</div>
						<div>
							<dt>Major</dt>
							<dd>Software Engineering</dd>
						</div>
						<div>
							<dt>Focus</dt>
							<dd>Web / AI Apps / NLP / LLMs</dd>
						</div>
					</dl>
				</aside>
			</section>

			<section class="about-section" aria-labelledby="stage-title">
				<div class="section-heading">
					<p class="eyebrow dark">education // stages</p>
					<h2 id="stage-title">Education & Stage Focus</h2>
				</div>
				<div class="timeline">
					{
						milestones.map((item) => (
							<article>
								<p class="stage">{item.stage}</p>
								<h3>{item.school}</h3>
								<p class="meta">
									{item.college} / {item.major}
								</p>
								<p>{item.focus}</p>
							</article>
						))
					}
				</div>
			</section>

			<section class="about-section focus-section" aria-labelledby="focus-title">
				<div class="section-heading">
					<p class="eyebrow dark">work // focus</p>
					<h2 id="focus-title">What I Work On</h2>
				</div>
				<div class="focus-grid">
					{
						focusCards.map((card) => (
							<article>
								<p class="card-stage">{card.stage}</p>
								<h3>{card.title}</h3>
								<p>{card.text}</p>
							</article>
						))
					}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	:global(body) {
		background: #f3f7fb;
	}

	.about-page {
		width: 100%;
		max-width: none;
		margin: 0;
		padding: 0;
		color: #0f172a;
	}

	.about-hero {
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(320px, 0.5fr);
		align-items: center;
		gap: clamp(2rem, 5vw, 5rem);
		padding: clamp(3rem, 7vw, 6rem) clamp(1.25rem, 6vw, 6rem);
		color: #0f172a;
		background:
			linear-gradient(115deg, #ffffff 0%, #eef7ff 58%, #f8fafc 58%, #ffffff 100%),
			#f8fafc;
		border-bottom: 1px solid rgba(15, 23, 42, 0.08);
		overflow: hidden;
		isolation: isolate;
	}

	.about-hero::before {
		position: absolute;
		inset: 0;
		z-index: -2;
		content: '';
		background:
			linear-gradient(rgba(15, 118, 110, 0.07) 1px, transparent 1px),
			linear-gradient(90deg, rgba(244, 63, 94, 0.06) 1px, transparent 1px);
		background-size: 44px 44px;
		mask-image: linear-gradient(90deg, black 0%, black 72%, transparent 100%);
	}

	.about-backdrop {
		position: absolute;
		inset: 0;
		z-index: -1;
		background:
			linear-gradient(135deg, rgba(20, 184, 166, 0.18), transparent 34%),
			linear-gradient(315deg, rgba(244, 63, 94, 0.12), transparent 36%),
			linear-gradient(90deg, rgba(255, 255, 255, 0.84), rgba(248, 250, 252, 0.72));
	}

	.about-backdrop::after {
		position: absolute;
		inset: 0 auto 0 0;
		width: 4px;
		content: '';
		background: #0f766e;
		opacity: 0.28;
	}

	.about-copy {
		max-width: 820px;
	}

	.eyebrow {
		display: inline-flex;
		margin: 0 0 1rem;
		padding: 0.35rem 0.6rem;
		border: 1px solid rgba(15, 118, 110, 0.18);
		color: #0f766e;
		font-size: 0.78rem;
		font-weight: 800;
		line-height: 1;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		background: rgba(255, 255, 255, 0.78);
	}

	.eyebrow.dark {
		border-color: rgba(15, 118, 110, 0.2);
		color: #0f766e;
		background: rgba(20, 184, 166, 0.1);
	}

	.about-hero h1 {
		margin: 0;
		color: #0f172a;
		font-size: clamp(3.2rem, 9vw, 7rem);
		line-height: 0.9;
	}

	.lead {
		max-width: 760px;
		margin: 1.35rem 0 0;
		padding-left: 1rem;
		border-left: 4px solid #14b8a6;
		color: #334155;
		font-size: clamp(1.05rem, 2.2vw, 1.35rem);
		line-height: 1.8;
	}

	.about-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 2rem;
	}

	.about-actions a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 48px;
		padding: 0 1.05rem;
		border: 1px solid rgba(15, 23, 42, 0.12);
		color: #0f172a;
		font-size: 0.95rem;
		font-weight: 800;
		line-height: 1;
		text-decoration: none;
		transition:
			transform 180ms ease,
			border-color 180ms ease,
			background 180ms ease;
	}

	.about-actions a:hover {
		transform: translateY(-2px);
	}

	.primary-action {
		color: #ffffff !important;
		background: #0f172a;
		box-shadow: 0 14px 32px rgba(15, 23, 42, 0.22);
	}

	.primary-action:hover {
		border-color: #14b8a6;
		background: #111827;
		color: #ffffff;
	}

	.ghost-action {
		background: rgba(255, 255, 255, 0.78);
	}

	.ghost-action:hover {
		border-color: #0f766e;
		color: #0f172a;
		background: #ffffff;
	}

	.identity-panel {
		position: relative;
		width: min(100%, 430px);
		justify-self: end;
		border: 1px solid rgba(15, 23, 42, 0.18);
		background: #0f172a;
		box-shadow:
			0 24px 80px rgba(15, 23, 42, 0.22),
			inset 0 1px 0 rgba(255, 255, 255, 0.08);
		overflow: hidden;
	}

	.identity-panel::before {
		position: absolute;
		inset: 0;
		content: '';
		background:
			linear-gradient(90deg, rgba(20, 184, 166, 0.18), transparent 42%),
			linear-gradient(180deg, transparent, rgba(251, 191, 36, 0.12));
		pointer-events: none;
	}

	.panel-topbar {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.9rem 1rem;
		border-bottom: 1px solid rgba(226, 232, 240, 0.12);
		color: #e2e8f0;
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
	}

	.panel-topbar span {
		width: 0.68rem;
		height: 0.68rem;
		background: #14b8a6;
	}

	.panel-topbar span:nth-child(2) {
		background: #fbbf24;
	}

	.panel-topbar span:nth-child(3) {
		margin-right: 0.3rem;
		background: #f43f5e;
	}

	.identity-panel dl {
		display: grid;
		margin: 0;
	}

	.identity-panel div {
		display: grid;
		grid-template-columns: 0.85fr 1.15fr;
		gap: 1rem;
		padding: 1rem;
		border-bottom: 1px solid rgba(226, 232, 240, 0.1);
	}

	.identity-panel div:last-child {
		border-bottom: 0;
	}

	.identity-panel dt {
		color: #94a3b8;
		font-size: 0.78rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	.identity-panel dd {
		margin: 0;
		color: #ffffff;
		font-weight: 800;
	}

	.about-section {
		padding: clamp(3rem, 6vw, 5rem) clamp(1.25rem, 6vw, 6rem);
		background: #ffffff;
	}

	.focus-section {
		background:
			linear-gradient(rgba(15, 118, 110, 0.04) 1px, transparent 1px),
			linear-gradient(90deg, rgba(15, 118, 110, 0.04) 1px, transparent 1px),
			#f8fafc;
		background-size: 36px 36px;
	}

	.section-heading {
		max-width: 760px;
		margin-bottom: 2rem;
	}

	.section-heading h2 {
		margin: 0;
		color: #0f172a;
		font-size: clamp(2rem, 4vw, 3.4rem);
		line-height: 1;
	}

	.timeline {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.1rem;
		max-width: 1080px;
	}

	.timeline article,
	.focus-grid article {
		position: relative;
		padding: 1.25rem;
		border: 1px solid rgba(15, 23, 42, 0.1);
		background: #ffffff;
		box-shadow: 0 18px 50px rgba(15, 23, 42, 0.06);
	}

	.timeline article {
		display: grid;
		grid-template-columns: minmax(130px, 0.25fr) minmax(0, 1fr);
		column-gap: 1.25rem;
		border-left: 4px solid #14b8a6;
	}

	.timeline article::before {
		position: absolute;
		top: 1.35rem;
		left: -0.58rem;
		width: 0.85rem;
		height: 0.85rem;
		content: '';
		background: #f43f5e;
		border: 3px solid #ffffff;
		box-shadow: 0 0 0 1px rgba(244, 63, 94, 0.24);
	}

	.focus-grid {
		counter-reset: focus-step;
	}

	.focus-grid article {
		counter-increment: focus-step;
		padding-top: 4.25rem;
	}

	.focus-grid article::before {
		position: absolute;
		top: 1.25rem;
		left: 1.25rem;
		display: grid;
		place-items: center;
		width: 2rem;
		height: 2rem;
		color: #ffffff;
		font-size: 0.78rem;
		font-weight: 900;
		content: counter(focus-step, decimal-leading-zero);
		background: #0f172a;
	}

	.stage,
	.card-stage {
		margin: 0;
		color: #f43f5e;
		font-size: 0.78rem;
		font-weight: 900;
		text-transform: uppercase;
		letter-spacing: 0.12em;
	}

	.stage {
		grid-row: 1 / span 3;
	}

	.card-stage {
		margin-bottom: 0.75rem;
	}

	.timeline h3,
	.focus-grid h3 {
		margin: 0 0 0.5rem;
		color: #0f172a;
		font-size: clamp(1.35rem, 2.4vw, 1.8rem);
	}

	.meta {
		margin: 0 0 1rem;
		color: #0f766e;
		font-weight: 800;
	}

	.timeline p,
	.focus-grid p {
		color: #475569;
		line-height: 1.8;
	}

	.timeline .stage,
	.focus-grid .card-stage {
		color: #f43f5e;
	}

	.focus-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	@media (max-width: 900px) {
		.about-hero {
			background: #f8fafc;
		}

		.about-hero,
		.timeline,
		.focus-grid {
			grid-template-columns: 1fr;
		}

		.about-hero::before {
			mask-image: none;
		}

		.about-backdrop {
			background:
				linear-gradient(135deg, rgba(20, 184, 166, 0.18), transparent 36%),
				linear-gradient(315deg, rgba(244, 63, 94, 0.12), transparent 42%),
				#f8fafc;
		}

		.identity-panel {
			justify-self: start;
		}
	}

	@media (max-width: 560px) {
		.about-hero,
		.about-section {
			padding: 2.25rem 1rem 3rem;
		}

		.about-actions a {
			width: 100%;
		}

		.identity-panel div {
			grid-template-columns: 1fr;
			gap: 0.25rem;
		}

		.timeline article {
			grid-template-columns: 1fr;
		}

		.stage {
			grid-row: auto;
			margin-bottom: 0.8rem;
		}
	}
</style>
